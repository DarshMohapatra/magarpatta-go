generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String        @id @default(cuid())
  phone       String        @unique // 10-digit Indian mobile, no +91 prefix
  firebaseUid String?       @unique
  name        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  addresses   UserAddress[]
  orders      Order[]
  feedback    OrderFeedback[]

  @@index([phone])
}

model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  society   String
  building  String
  flat      String
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, society, building, flat])
  @@index([userId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  phone     String   @unique
  society   String?
  building  String?
  flat      String?
  source    String? // e.g. "landing_cta", "signup_abandoned"
  createdAt DateTime @default(now())

  @@index([society])
  @@index([createdAt])
}

model Society {
  id        String     @id @default(cuid())
  name      String     @unique
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())
  buildings Building[]
}

model Building {
  id            String   @id @default(cuid())
  societyId     String
  name          String
  floors        Int
  flatsPerFloor Int
  createdAt     DateTime @default(now())
  society       Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([societyId, name])
  @@index([societyId])
}

enum VendorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model Vendor {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String    @unique
  hub         String
  description String?
  accent      String?
  vendorType  String    @default("restaurant") // restaurant | cafe | bakery | sweets | grocery | meat | pharmacy
  tags        String[]  @default([])            // cuisines or subcategories
  rating      Float?
  etaMinutes  Int       @default(25)
  costForTwo  Int?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]

  // Approval lifecycle
  approvalStatus VendorApprovalStatus @default(APPROVED)
  approvalNote   String?
  submittedAt    DateTime?
  approvedAt     DateTime?

  // Owner login / KYC
  ownerName         String?
  ownerPhone        String?  @unique
  ownerEmail        String?
  ownerPasswordHash String?   // sha256 hex — dev-only, replace with bcrypt in prod

  // KYC docs
  gstin       String?
  fssaiNumber String?
  drugLicense String?
  panNumber   String?
  aadhaarLast4 String?

  // Address + geo
  addressLine String?
  latitude    Float?
  longitude   Float?

  // Hours (24h "HH:MM")
  openTime  String?
  closeTime String?

  // Payouts
  bankAccountNumber String?
  bankIfsc          String?
  bankAccountName   String?
  upiId             String?
  commissionPct     Int    @default(15)

  // Fulfilment model
  supportsSelfDelivery Boolean @default(false)
  selfDeliveryFeeInr   Int?

  orders   Order[]
  feedback OrderFeedback[]

  @@index([approvalStatus])
  @@index([hub])
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String    @unique
  glyph     String?
  order     Int       @default(0)
  products  Product[]
}

model Product {
  id          String      @id @default(cuid())
  vendorId    String
  categoryId  String
  name        String
  description String?
  priceInr    Int
  mrpInr      Int?
  unit        String?
  isVeg       Boolean     @default(true)
  isRegulated Boolean     @default(true)
  inStock     Boolean     @default(true)
  accent      String?
  glyph       String?
  tagline     String?
  imageUrl    String?
  createdAt   DateTime    @default(now())
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([inStock])
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  UPI
  CARD
  NET_BANKING
}

enum OrderFulfilmentMode {
  PLATFORM_RIDER
  VENDOR_SELF
}

enum CouponType {
  PERCENT
  FLAT
  FREE_DELIVERY
}

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  description    String
  type           CouponType
  percentOff     Int?
  flatOffInr     Int?
  minSubtotalInr Int        @default(0)
  maxDiscountInr Int?
  active         Boolean    @default(true)
  validUntil     DateTime?
  perUserLimit   Int        @default(1)
  usageCount     Int        @default(0)
  createdAt      DateTime   @default(now())

  @@index([active])
}

model Order {
  id             String        @id @default(cuid())
  userId         String
  vendorId       String?
  status         OrderStatus   @default(PLACED)
  paymentMethod  PaymentMethod @default(COD)

  // Address snapshot
  society        String
  building       String
  flat           String

  // Rupee totals
  subtotalInr      Int
  convenienceInr   Int          @default(0)
  taxInr           Int          @default(0)
  addOnsInr        Int          @default(0)
  deliveryFeeInr   Int
  discountInr      Int          @default(0)
  couponCode       String?
  totalInr         Int

  giftWrap       Boolean       @default(false)
  insurance      Boolean       @default(false)
  deliveryMode   String        @default("standard")

  // Vendor snapshot
  vendorName     String?
  vendorHub      String?

  // Fulfilment
  hub            String?
  fulfilmentMode OrderFulfilmentMode @default(PLATFORM_RIDER)

  // Rider assignment
  riderPhone     String?
  riderName      String?

  notes          String?

  // Timeline timestamps — populated by real actors
  placedAt          DateTime  @default(now())
  vendorAcceptedAt  DateTime?
  vendorReadyAt     DateTime?
  riderAssignedAt   DateTime?
  acceptedAt        DateTime?   // legacy — mirrored to vendorAcceptedAt
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor         Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  feedback       OrderFeedback?

  @@index([userId])
  @@index([vendorId])
  @@index([status])
  @@index([placedAt])
  @@index([riderPhone])
  @@index([hub])
  @@index([fulfilmentMode])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  name        String
  vendorName  String
  unit        String?
  priceInr    Int
  mrpInr      Int?
  isRegulated Boolean @default(true)
  quantity    Int
  accent      String?
  glyph       String?
  imageUrl    String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model OrderFeedback {
  id               String   @id @default(cuid())
  orderId          String   @unique
  userId           String
  vendorId         String?
  riderPhone       String?
  // 1–5 stars, null = skipped
  foodRating       Int?
  foodComment      String?
  deliveryRating   Int?
  deliveryComment  String?
  createdAt        DateTime @default(now())

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([riderPhone])
}

enum RiderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model RiderProfile {
  id             String              @id @default(cuid())
  phone          String              @unique // 10-digit, no +91
  name           String
  email          String?
  aadhaarNumber  String?
  dlNumber       String?
  vehicleType    String?             // bicycle | scooter | motorcycle
  vehicleNumber  String?
  approvalStatus RiderApprovalStatus @default(PENDING)
  approvalNote   String?
  perDropInr     Int                 @default(30)
  onDuty         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  approvedAt     DateTime?

  @@index([approvalStatus])
}

enum AdminRole {
  SUPER_ADMIN
  OPS
  FINANCE
  SUPPORT
}

model Admin {
  id           String    @id @default(cuid())
  phone        String    @unique
  email        String?
  name         String
  role         AdminRole @default(OPS)
  passwordHash String    // legacy — retained for audit; OTP is the live signin path
  createdAt    DateTime  @default(now())
}

/// One active OTP per (phone, purpose). Upserted on each send.
/// codeHash is sha256 of the plaintext code — we never store plaintext.
model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  purpose    String    // CUSTOMER_SIGNIN | VENDOR_SIGNIN | VENDOR_REGISTER | RIDER_SIGNIN | RIDER_REGISTER | ADMIN_SIGNIN
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([phone, purpose])
  @@index([phone])
}
