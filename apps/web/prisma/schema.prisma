generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String        @id @default(cuid())
  phone       String        @unique // 10-digit Indian mobile, no +91 prefix
  firebaseUid String?       @unique
  name        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  addresses   UserAddress[]
  orders      Order[]

  @@index([phone])
}

model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  society   String
  building  String
  flat      String
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, society, building, flat])
  @@index([userId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  phone     String   @unique
  society   String?
  building  String?
  flat      String?
  source    String? // e.g. "landing_cta", "signup_abandoned"
  createdAt DateTime @default(now())

  @@index([society])
  @@index([createdAt])
}

model Society {
  id        String     @id @default(cuid())
  name      String     @unique
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())
  buildings Building[]
}

model Building {
  id            String   @id @default(cuid())
  societyId     String
  name          String
  floors        Int
  flatsPerFloor Int
  createdAt     DateTime @default(now())
  society       Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([societyId, name])
  @@index([societyId])
}

model Vendor {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String    @unique
  hub         String
  description String?
  accent      String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String    @unique
  glyph     String?
  order     Int       @default(0)
  products  Product[]
}

model Product {
  id          String      @id @default(cuid())
  vendorId    String
  categoryId  String
  name        String
  description String?
  priceInr    Int
  mrpInr      Int?
  unit        String?
  isVeg       Boolean     @default(true)
  isRegulated Boolean     @default(true)
  inStock     Boolean     @default(true)
  accent      String?
  glyph       String?
  tagline     String?
  imageUrl    String?
  createdAt   DateTime    @default(now())
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([inStock])
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  UPI
  CARD
  NET_BANKING
}

enum CouponType {
  PERCENT
  FLAT
  FREE_DELIVERY
}

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  description    String
  type           CouponType
  percentOff     Int?       // 1..100 when type = PERCENT
  flatOffInr     Int?       // rupees when type = FLAT
  minSubtotalInr Int        @default(0)
  maxDiscountInr Int?       // cap for percent coupons
  active         Boolean    @default(true)
  validUntil     DateTime?
  perUserLimit   Int        @default(1)
  usageCount     Int        @default(0)
  createdAt      DateTime   @default(now())

  @@index([active])
}

model Order {
  id             String        @id @default(cuid())
  userId         String
  status         OrderStatus   @default(PLACED)
  paymentMethod  PaymentMethod @default(COD)

  // Address snapshot at time of order
  society        String
  building       String
  flat           String

  // Rupee totals — subtotal is MRP-based, convenience fee captures the
  // per-unit markup we add on non-regulated items at checkout.
  subtotalInr      Int
  convenienceInr   Int          @default(0)
  taxInr           Int          @default(0)
  addOnsInr        Int          @default(0)
  deliveryFeeInr   Int
  discountInr      Int          @default(0)
  couponCode       String?
  totalInr         Int

  giftWrap       Boolean       @default(false)
  insurance      Boolean       @default(false)
  deliveryMode   String        @default("standard")

  // Vendor snapshot — for single-vendor orders, the pickup shop
  vendorName     String?
  vendorHub      String?

  notes          String?
  placedAt       DateTime      @default(now())
  acceptedAt     DateTime?
  pickedUpAt     DateTime?
  deliveredAt    DateTime?

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([placedAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  name        String
  vendorName  String
  unit        String?
  priceInr    Int       // what we charged per unit (MRP for regulated, MRP+1 for non-reg)
  mrpInr      Int?      // MRP shown to customer for line total display
  isRegulated Boolean @default(true)
  quantity    Int
  accent      String?
  glyph       String?
  imageUrl    String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}
